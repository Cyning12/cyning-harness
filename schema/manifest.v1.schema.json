{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyning.dev/schemas/cyning-harness/manifest.v1.json",
  "title": "cyning-harness VersionManifest",
  "description": "业务仓钉住的产品包版本与接入参数（本体 VersionManifest · v0.3+）",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "preset", "ide"],
  "properties": {
    "version": {
      "type": "string",
      "description": "已同步的产品包 semver（或 git describe）"
    },
    "preset": {
      "type": "string",
      "description": "AdoptedProfile preset 名"
    },
    "ide": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["cursor", "claude", "agents"]
      },
      "uniqueItems": true,
      "description": "启用的 IDE 轨"
    },
    "from_version": {
      "type": ["string", "null"],
      "description": "upgrade 前版本；init 时为 null"
    },
    "upgraded_at": {
      "type": "string",
      "format": "date-time",
      "description": "最近一次 install/upgrade 写入时间（UTC ISO8601）"
    }
  }
}
